{
  "name": "blockchain-caliper-benchmark",
  "version": "1.0.0",
  "description": "Benchmark project",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "node": "hardhat node",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "bind": "npx --package @hyperledger/caliper-cli caliper bind --caliper-bind-sut ethereum:1.2.1",
    "benchmark": "npx --package @hyperledger/caliper-cli caliper launch manager --caliper-workspace ./caliper-workspace --caliper-networkconfig networks/ethereum-local.yaml --caliper-benchconfig benchmarks/config.yaml --caliper-flow-only-test"
  },
  "devDependencies": {
    "@hyperledger/caliper-cli": "0.5.0",
    "@hyperledger/caliper-ethereum": "0.5.0",
    "@nomiclabs/hardhat-ethers": "2.2.3",
    "ethers": "^5.7.2",
    "ganache": "^7.9.2",
    "hardhat": "2.22.17"
  },
  "dependencies": {
    "web3": "^1.2.2"
  }
}
